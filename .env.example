APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Midtrans (Snap + notifikasi HTTP)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true
# URL webhook (POST) — samakan dengan yang di dashboard Midtrans: {APP_URL}/midtrans/notification
MIDTRANS_CALLBACK_URL="${APP_URL}/midtrans/notification"

# Pembayaran manual (siswa — panduan transfer). Kosongkan metode yang tidak dipakai.
PAYMENT_BRI_ACCOUNT=
PAYMENT_BRI_NAME=
PAYMENT_BCA_ACCOUNT=
PAYMENT_BCA_NAME=
PAYMENT_BNI_ACCOUNT=
PAYMENT_BNI_NAME=
PAYMENT_DANA_ID=
PAYMENT_DANA_NAME=
PAYMENT_GOPAY_ID=
PAYMENT_GOPAY_NAME=
PAYMENT_SHOPEEPAY_ID=
PAYMENT_SHOPEEPAY_NAME=
# Path relatif dari folder public, contoh: images/payment/qris.png
PAYMENT_QRIS_PATH=images/payment/qris.svg

# WhatsApp (Fonnte) — fallback jika belum diisi di Pengaturan WhatsApp (database)
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_API_KEY=
# Aktifkan pengiriman jika baris whatsapp.enabled belum ada di tabel settings
WHATSAPP_ENABLED=false
